# Convex
CONVEX_DEPLOYMENT=              # e.g. dev:modest-swan-643 or prod:your-slug
NEXT_PUBLIC_CONVEX_URL=         # e.g. https://your-slug.convex.cloud
CONVEX_SITE_URL=                # e.g. https://your-slug.convex.site

# WorkOS AuthKit
WORKOS_CLIENT_ID=               # client_... from WorkOS dashboard
WORKOS_API_KEY=                 # sk_test_... or sk_live_...
WORKOS_COOKIE_PASSWORD=         # 32+ char random hex string for cookie encryption
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback  # Update for production

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # Generate with: npx web-push generate-vapid-keys

# ── Convex Environment Variables (set via `npx convex env set`) ──
# OPENROUTER_API_KEY=           # AI features (task parsing, subtask suggestions)
# VAPID_PUBLIC_KEY=             # Same as NEXT_PUBLIC_VAPID_PUBLIC_KEY
# VAPID_PRIVATE_KEY=            # From VAPID key generation
# VAPID_SUBJECT=                # mailto:your-email@example.com
# TELEGRAM_BOT_TOKEN=           # Optional: Telegram bot integration
# TELEGRAM_WEBHOOK_SECRET=      # Optional: Telegram webhook verification
# SITE_URL=                     # Your production URL (used for Telegram deep links)
# WORKOS_CLIENT_ID=             # Same as above
# WORKOS_API_KEY=               # Same as above
# WORKOS_ENVIRONMENT_ID=        # From WorkOS dashboard
# JWKS=                         # WorkOS JWKS JSON for token verification
# JWT_PRIVATE_KEY=              # WorkOS JWT signing key
